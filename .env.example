# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN="your_bot_token"
TELEGRAM_CHAT_ID="your_chat_id"

# Claude API (https://console.anthropic.com/)
CLAUDE_API_KEY="sk-ant-..."

